{
    "name": "hr-backend",
    "version": "1.0.0",
    "description": "HR Management System Backend API",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "swagger": "node swagger-autogen.js",
        "dev": "npm run swagger && ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "npm run swagger && npx prisma generate && tsc && node -e \"require('fs').copyFileSync('src/config/swagger-output.json', 'dist/config/swagger-output.json')\""
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "@supabase/supabase-js": "^2.95.3",
        "@types/multer": "^2.0.0",
        "@types/ws": "^8.18.1",
        "bcryptjs": "^3.0.3",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "date-fns": "^4.1.0",
        "dotenv": "^16.3.1",
        "exceljs": "^4.4.0",
        "express": "^4.18.2",
        "googleapis": "^171.0.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.3",
        "jspdf": "^4.0.0",
        "jspdf-autotable": "^5.0.7",
        "morgan": "^1.10.0",
        "multer": "^2.0.2",
        "node-cache": "^5.1.2",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.7",
        "otplib": "^13.3.0",
        "path-to-regexp": "^0.1.12",
        "qrcode": "^1.5.4",
        "selfsigned": "^5.5.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "ws": "^8.20.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.19.39",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^8.0.0",
        "@types/qrcode": "^1.5.6",
        "@types/selfsigned": "^2.0.4",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "prisma": "^5.22.0",
        "swagger-autogen": "^2.23.7",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    },
    "prisma": {
        "seed": "npx ts-node prisma/seed.ts"
    }
}
